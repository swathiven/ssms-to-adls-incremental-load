{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "pojdf"
		},
		"ls_adls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls'"
		},
		"ls_azuresql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_azuresql'"
		},
		"ls_ssms_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_ssms'"
		},
		"ls_adls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://projectstorage321.dfs.core.windows.net/"
		},
		"ls_azuresql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "tanvi.database.windows.net"
		},
		"ls_azuresql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "tanvi"
		},
		"ls_azuresql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adf_user"
		},
		"ls_ssms_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "LAPTOP-A61EKOP8"
		},
		"ls_ssms_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "tanvi"
		},
		"ls_ssms_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adf_user"
		},
		"trigger1_properties_pipeline1_parameters_body": {
			"type": "string",
			"defaultValue": "@string(triggerBody())"
		},
		"trigger1_properties_pipeline1_parameters_file": {
			"type": "string",
			"defaultValue": "@triggerBody()"
		},
		"trigger1_properties_pipeline1_parameters_folder": {
			"type": "string",
			"defaultValue": "@triggerBody()"
		},
		"trigger1_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/435059ae-f4a8-4963-b132-361a892d8586/resourceGroups/proman/providers/Microsoft.Storage/storageAccounts/projectstorage321"
		},
		"trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_inputfilename": {
			"type": "string",
			"defaultValue": "@triggerBody().fileName"
		},
		"trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_outputfilename": {
			"type": "string",
			"defaultValue": "@triggerBody().fileName"
		},
		"trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_folderpath": {
			"type": "string",
			"defaultValue": "@triggerBody().folderPath"
		},
		"trigger2_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/435059ae-f4a8-4963-b132-361a892d8586/resourceGroups/proman/providers/Microsoft.Storage/storageAccounts/projectstorage321"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "pojdf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_accountKey": {
						"value": "[parameters('ls_adls_accountKey')]"
					},
					"ls_azuresql_password": {
						"value": "[parameters('ls_azuresql_password')]"
					},
					"ls_ssms_password": {
						"value": "[parameters('ls_ssms_password')]"
					},
					"ls_adls_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_properties_typeProperties_url')]"
					},
					"ls_azuresql_properties_typeProperties_server": {
						"value": "[parameters('ls_azuresql_properties_typeProperties_server')]"
					},
					"ls_azuresql_properties_typeProperties_database": {
						"value": "[parameters('ls_azuresql_properties_typeProperties_database')]"
					},
					"ls_azuresql_properties_typeProperties_userName": {
						"value": "[parameters('ls_azuresql_properties_typeProperties_userName')]"
					},
					"ls_ssms_properties_typeProperties_server": {
						"value": "[parameters('ls_ssms_properties_typeProperties_server')]"
					},
					"ls_ssms_properties_typeProperties_database": {
						"value": "[parameters('ls_ssms_properties_typeProperties_database')]"
					},
					"ls_ssms_properties_typeProperties_userName": {
						"value": "[parameters('ls_ssms_properties_typeProperties_userName')]"
					},
					"trigger1_properties_pipeline1_parameters_body": {
						"value": "[parameters('trigger1_properties_pipeline1_parameters_body')]"
					},
					"trigger1_properties_pipeline1_parameters_file": {
						"value": "[parameters('trigger1_properties_pipeline1_parameters_file')]"
					},
					"trigger1_properties_pipeline1_parameters_folder": {
						"value": "[parameters('trigger1_properties_pipeline1_parameters_folder')]"
					},
					"trigger1_properties_typeProperties_scope": {
						"value": "[parameters('trigger1_properties_typeProperties_scope')]"
					},
					"trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_inputfilename": {
						"value": "[parameters('trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_inputfilename')]"
					},
					"trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_outputfilename": {
						"value": "[parameters('trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_outputfilename')]"
					},
					"trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_folderpath": {
						"value": "[parameters('trigger2_properties_pl_copydata_adls_adls_usingmapping in copy activity_parameters_folderpath')]"
					},
					"trigger2_properties_typeProperties_scope": {
						"value": "[parameters('trigger2_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}
{
	"name": "pipeline1",
	"properties": {
		"activities": [
			{
				"name": "Delete1",
				"type": "Delete",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [
					{
						"name": "files deleted",
						"value": "all files deleted in outputcontainer"
					}
				],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_adls_target",
						"type": "DatasetReference",
						"parameters": {
							"filename": "*"
						}
					},
					"logStorageSettings": {
						"linkedServiceName": {
							"referenceName": "ls_adls",
							"type": "LinkedServiceReference"
						},
						"path": "data/ouput"
					},
					"enableLogging": true,
					"storeSettings": {
						"type": "AzureBlobFSReadSettings",
						"recursive": true,
						"wildcardFileName": "*.csv",
						"enablePartitionDiscovery": false
					}
				}
			}
		],
		"annotations": []
	}
}